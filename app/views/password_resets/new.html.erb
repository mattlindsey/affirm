<%= content_for :title, "Reset Password — Affirm" %>

<div class="min-h-screen flex items-center justify-center -mt-28">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2 text-center">Forgot your password?</h1>
      <p class="text-gray-600 text-sm text-center mb-6">Enter your email address and we'll send you a reset link.</p>

      <%= form_with url: password_reset_path, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email,
                autocomplete: "email",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "you@example.com" %>
        </div>

        <%= f.submit "Send reset link",
              class: "w-full py-2 px-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition" %>
      <% end %>

      <p class="mt-6 text-center text-sm text-gray-600">
        Remembered it? <%= link_to "Sign in", login_path, class: "text-blue-600 hover:underline font-medium" %>
      </p>
    </div>
  </div>
</div>
