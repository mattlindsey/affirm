<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-4xl font-bold text-gray-800 mb-8">Blog</h1>

  <% if @posts.any? %>
    <div class="space-y-4">
      <% @posts.each do |post| %>
        <%= link_to post_path(post.slug), class: "block group" do %>
          <div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition bg-white">
            <h2 class="text-xl font-semibold text-gray-800 group-hover:text-blue-600 transition-colors"><%= post.title %></h2>
            <p class="text-sm text-gray-400 mt-1"><%= post.published_at.strftime("%B %d, %Y") %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 italic">No posts yet.</p>
  <% end %>
</div>
